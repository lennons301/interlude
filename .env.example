# Auth — one of these is required:
# Option 1: Use your Claude Code subscription (Pro/Max/Enterprise)
# Credentials are auto-detected from ~/.claude/.credentials.json
# No env var needed — just run `claude login` first.

# Option 2: Use an Anthropic API key (separate billing)
# ANTHROPIC_API_KEY=sk-ant-...

# Required — GitHub personal access token (repo scope) for git push
GIT_TOKEN=ghp_...

# Optional
GIT_USER_NAME=Interlude Agent
GIT_USER_EMAIL=agent@interlude.dev
KEEP_CONTAINERS=false

# Agent limits (per task)
MAX_TURNS=50
MAX_BUDGET_USD=5.00
